  "keyFeatures": [
    "Reactive database with real-time synchronization",
    "TypeScript/JavaScript server functions (queries, mutations, actions)",
    "Automatic schema validation and type generation",
    "Full-text and vector search capabilities",
    "Built-in authentication and file storage",
    "Scheduled functions and cron jobs",
    "Self-hosting with Docker or prebuilt binaries",
    "React, Next.js, and browser client libraries",
    "Component system for modular backend code",
    "SQL database backends (SQLite, PostgreSQL, MySQL)",
    "S3-compatible storage integration"
  ],
  "publicApiSurface": [
    "convex/server: query, mutation, action, internalQuery, internalMutation, internalAction",
    "convex/server: defineSchema, defineTable",
    "convex/server: httpRouter, cronJobs",
    "convex/react: useQuery, useMutation, useAction, ConvexProvider, ConvexReactClient",
    "convex/browser: ConvexHttpClient",
    "convex/nextjs: preloadQuery, fetchQuery, fetchMutation, fetchAction",
    "CLI: convex dev, convex deploy, convex import, convex export, convex env, convex data",
    "Database: db.query(), db.get(), db.insert(), db.patch(), db.replace(), db.delete()",
    "Search: db.query(table).withSearchIndex(), db.query(table).withVectorIndex()",
    "Storage: storage.store(), storage.getUrl(), storage.getMetadata(), storage.delete()",
    "Auth: ctx.auth.getUserIdentity()",
    "Scheduler: scheduler.runAfter(), scheduler.runAt()"
  ]
